{
    "compilerOptions": {
        "target": "ESNext",
        "lib": ["ESNext", "dom"],
        "types": ["cypress", "node", "jquery", "cypress-axe"],
        "module": "es2015",
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "isolatedModules": true
    },
    "include": ["**/*.ts"]
}
